# WireGuard Client: {{ item.name }}
# Generated by Ansible — do not commit private keys to version control
#
# Import into WireGuard client:
#   Linux:   wg-quick up /path/to/{{ item.name }}.conf
#   macOS:   WireGuard app → Import tunnel(s) from file
#   Windows: WireGuard app → Import tunnel(s) from file
#   Mobile:  qrencode -t ansiutf8 < {{ item.name }}.conf
#
# IMPORTANT: Replace <PASTE_YOUR_PRIVATE_KEY_HERE> with the private
# key that corresponds to the public key configured for this peer.

[Interface]
Address = {{ item.allowed_ips }}
PrivateKey = <PASTE_YOUR_PRIVATE_KEY_HERE>
# DNS = 1.1.1.1, 8.8.8.8

[Peer]
PublicKey = {{ wg_server_public_key.content | b64decode | trim }}
{% if item.preshared_key is defined %}
PresharedKey = {{ item.preshared_key }}
{% endif %}
Endpoint = {{ fqdn | default(ansible_default_ipv4.address, true) }}:{{ wireguard_port }}
# Split-tunnel: only VPN subnet + LXD container subnet route through tunnel.
AllowedIPs = {{ wireguard_network }}, {{ lxd_network }}
PersistentKeepalive = 25
