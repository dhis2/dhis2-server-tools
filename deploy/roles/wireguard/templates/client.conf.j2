# WireGuard Client: {{ item.name }}
# Generated by Ansible — do not commit to version control

[Interface]
Address = {{ item.allowed_ips }}
PrivateKey = {{ item._private_key }}
# DNS = 1.1.1.1, 8.8.8.8

[Peer]
PublicKey = {{ wg_server_public_key.content | b64decode | trim }}
{% if item._preshared_key is defined and item._preshared_key %}
PresharedKey = {{ item._preshared_key }}
{% endif %}
Endpoint = {{ fqdn | default(ansible_default_ipv4.address, true) }}:{{ wireguard_port }}
AllowedIPs = {{ wireguard_network }}, {{ lxd_network }}
PersistentKeepalive = 25
